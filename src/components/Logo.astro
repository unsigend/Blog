---
interface Props {
	class?: string
	size?: number
}

const { class: className, size = 36 } = Astro.props
---

<svg
	width={size}
	height={size}
	viewBox="0 0 32 32"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	class:list={['text-foreground dark:text-foreground-dark', className]}
	aria-hidden="true"
>
	<circle cx="16" cy="16" r="9" stroke="currentColor" stroke-width="2.5" fill="none"></circle>
	<path
		d="M 20 20 L 26 26"
		stroke="currentColor"
		stroke-width="2.5"
		stroke-linecap="round"></path>
	<circle cx="16" cy="16" r="2.5" fill="currentColor"></circle>
</svg>
